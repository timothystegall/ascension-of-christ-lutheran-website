---
title: Contact Us
permalink: /contact/
description: Contact Ascension of Christ Lutheran Church & Child Care in Beverly Hills, MI.
layout: base.njk
---

<div class="bg-dark-bg text-link font-serif max-w-[950px] mx-auto py-[40px] px-[20px]">

  <header class="text-center mb-[40px]">
    <h1 class="text-accent uppercase tracking-[4px] mb-[10px] text-[2rem]">Contact Us</h1>
    <p class="text-accent-blue italic">We'd love to hear from you. Fill out the form below and we'll be in touch shortly.</p>
  </header>

  <div id="form-wrapper" class="border border-[rgba(255,255,255,0.1)] bg-[rgba(255,255,255,0.02)] p-[30px] sm:p-[40px]">
    <form id="contact-form" novalidate>
      <input type="hidden" name="form_type" value="contact">

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-5">
        <div>
          <label for="first_name" class="block text-[0.8rem] uppercase tracking-[1px] text-accent-blue mb-[6px]">First Name <span class="text-accent">*</span></label>
          <input type="text" id="first_name" name="first_name" required class="w-full bg-[rgba(255,255,255,0.04)] border border-[rgba(255,255,255,0.15)] text-link px-3 py-2 focus:outline-none focus:border-accent transition-colors duration-200">
        </div>
        <div>
          <label for="last_name" class="block text-[0.8rem] uppercase tracking-[1px] text-accent-blue mb-[6px]">Last Name <span class="text-accent">*</span></label>
          <input type="text" id="last_name" name="last_name" required class="w-full bg-[rgba(255,255,255,0.04)] border border-[rgba(255,255,255,0.15)] text-link px-3 py-2 focus:outline-none focus:border-accent transition-colors duration-200">
        </div>
      </div>

      <div class="mb-5">
        <label for="email" class="block text-[0.8rem] uppercase tracking-[1px] text-accent-blue mb-[6px]">Email <span class="text-accent">*</span></label>
        <input type="email" id="email" name="email" required class="w-full bg-[rgba(255,255,255,0.04)] border border-[rgba(255,255,255,0.15)] text-link px-3 py-2 focus:outline-none focus:border-accent transition-colors duration-200">
      </div>

      <div class="mb-6">
        <label for="message" class="block text-[0.8rem] uppercase tracking-[1px] text-accent-blue mb-[6px]">Message <span class="text-accent">*</span></label>
        <textarea id="message" name="message" rows="6" required class="w-full bg-[rgba(255,255,255,0.04)] border border-[rgba(255,255,255,0.15)] text-link px-3 py-2 focus:outline-none focus:border-accent transition-colors duration-200 resize-y"></textarea>
      </div>

      <div id="form-status" class="mb-4 text-[0.9rem]"></div>

      <button type="submit" id="submit-btn" class="px-[24px] py-[10px] border border-accent text-accent uppercase tracking-[2px] text-[0.85rem] hover:bg-accent hover:text-dark-bg transition-colors duration-300 cursor-pointer disabled:opacity-50">
        Send Message
      </button>
    </form>
  </div>

</div>

<script>
  document.getElementById('contact-form').addEventListener('submit', async function (e) {
    e.preventDefault();
    const btn = document.getElementById('submit-btn');
    const status = document.getElementById('form-status');
    const wrapper = document.getElementById('form-wrapper');

    if (!this.checkValidity()) {
      this.reportValidity();
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Sending...';
    status.textContent = '';

    try {
      const res = await fetch('/api/submit-form', { method: 'POST', body: new FormData(this) });
      if (res.ok) {
        wrapper.innerHTML = '<div class="text-center py-[60px]"><p class="text-accent text-[1.5rem] uppercase tracking-[4px] mb-4">Thank You!</p><p class="text-link">Your message has been successfully submitted. We will be in touch shortly.</p></div>';
      } else {
        status.textContent = 'There was an error sending your message. Please try again or contact us directly.';
        status.className = 'mb-4 text-[0.9rem] text-red-400';
        btn.disabled = false;
        btn.textContent = 'Send Message';
      }
    } catch {
      status.textContent = 'There was an error sending your message. Please try again or contact us directly.';
      status.className = 'mb-4 text-[0.9rem] text-red-400';
      btn.disabled = false;
      btn.textContent = 'Send Message';
    }
  });
</script>
