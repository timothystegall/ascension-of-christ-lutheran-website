---
title: Withdrawal Form
permalink: /childcare/withdrawal/
description: Submit a child care withdrawal request for Ascension of Christ Child Care & Preschool.
layout: base.njk
---

{% include "partials/childcare-nav.html" %}

<div class="bg-dark-bg text-link font-serif max-w-[950px] mx-auto py-[40px] px-[20px]">

  <header class="text-center mb-[40px]">
    <h1 class="text-accent uppercase tracking-[4px] mb-[10px] text-[2rem]">Withdrawal Form</h1>
    <p class="text-accent-blue italic">Please complete all required fields and submit at least two weeks prior to your child's last day.</p>
  </header>

  <div id="form-wrapper" class="border border-[rgba(255,255,255,0.1)] bg-[rgba(255,255,255,0.02)] p-[30px] sm:p-[40px]">
    <form id="withdrawal-form" novalidate>
      <input type="hidden" name="form_type" value="withdrawal">

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-5">
        <div>
          <label for="first_name" class="block text-[0.8rem] uppercase tracking-[1px] text-accent-blue mb-[6px]">Child's First Name <span class="text-accent">*</span></label>
          <input type="text" id="first_name" name="first_name" required class="w-full bg-[rgba(255,255,255,0.04)] border border-[rgba(255,255,255,0.15)] text-link px-3 py-2 focus:outline-none focus:border-accent transition-colors duration-200">
        </div>
        <div>
          <label for="last_name" class="block text-[0.8rem] uppercase tracking-[1px] text-accent-blue mb-[6px]">Child's Last Name <span class="text-accent">*</span></label>
          <input type="text" id="last_name" name="last_name" required class="w-full bg-[rgba(255,255,255,0.04)] border border-[rgba(255,255,255,0.15)] text-link px-3 py-2 focus:outline-none focus:border-accent transition-colors duration-200">
        </div>
      </div>

      <div class="mb-5">
        <label for="contact_email" class="block text-[0.8rem] uppercase tracking-[1px] text-accent-blue mb-[6px]">Contact Email <span class="text-accent">*</span></label>
        <input type="email" id="contact_email" name="contact_email" required class="w-full bg-[rgba(255,255,255,0.04)] border border-[rgba(255,255,255,0.15)] text-link px-3 py-2 focus:outline-none focus:border-accent transition-colors duration-200">
      </div>

      <div class="mb-5">
        <span class="block text-[0.8rem] uppercase tracking-[1px] text-accent-blue mb-[6px]">Classroom(s) <span class="text-accent">*</span></span>
        <div class="flex flex-wrap gap-x-6 gap-y-2 mt-1">
          {% set classrooms = ["Baby Sprouts", "Tiny Sprouts", "Toddlers & Twos", "Preschool A & B", "Pre-K"] %}
          {% for room in classrooms %}
          <label class="flex items-center gap-2 cursor-pointer">
            <input type="checkbox" name="classrooms" value="{{ room }}" class="accent-[#c5a059] w-4 h-4">
            <span class="text-link text-[0.95rem]">{{ room }}</span>
          </label>
          {% endfor %}
        </div>
      </div>

      <div class="mb-5">
        <label for="withdrawal_type" class="block text-[0.8rem] uppercase tracking-[1px] text-accent-blue mb-[6px]">Type of Withdrawal <span class="text-accent">*</span></label>
        <select id="withdrawal_type" name="withdrawal_type" required class="w-full bg-[rgba(255,255,255,0.04)] border border-[rgba(255,255,255,0.15)] text-link px-3 py-2 focus:outline-none focus:border-accent transition-colors duration-200">
          <option value="" disabled selected>Select type...</option>
          <option value="Summer">Summer</option>
          <option value="Temporary">Temporary</option>
          <option value="Permanent">Permanent</option>
        </select>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5 mb-5">
        <div>
          <label for="last_day" class="block text-[0.8rem] uppercase tracking-[1px] text-accent-blue mb-[6px]">Last Day of Care <span class="text-accent">*</span></label>
          <input type="date" id="last_day" name="last_day" required class="w-full bg-[rgba(255,255,255,0.04)] border border-[rgba(255,255,255,0.15)] text-link px-3 py-2 focus:outline-none focus:border-accent transition-colors duration-200">
        </div>
        <div>
          <label for="return_date" class="block text-[0.8rem] uppercase tracking-[1px] text-accent-blue mb-[6px]">Return Date <span class="text-[0.75rem] normal-case tracking-normal text-link/60">(if applicable)</span></label>
          <input type="date" id="return_date" name="return_date" class="w-full bg-[rgba(255,255,255,0.04)] border border-[rgba(255,255,255,0.15)] text-link px-3 py-2 focus:outline-none focus:border-accent transition-colors duration-200">
        </div>
      </div>

      <div class="mb-6">
        <label for="comments" class="block text-[0.8rem] uppercase tracking-[1px] text-accent-blue mb-[6px]">Comments or Reason for Withdrawal</label>
        <textarea id="comments" name="comments" rows="4" class="w-full bg-[rgba(255,255,255,0.04)] border border-[rgba(255,255,255,0.15)] text-link px-3 py-2 focus:outline-none focus:border-accent transition-colors duration-200 resize-y"></textarea>
      </div>

      <div class="mb-6 border border-[rgba(255,255,255,0.1)] bg-[rgba(255,255,255,0.02)] p-4">
        <label class="flex items-start gap-3 cursor-pointer">
          <input type="checkbox" name="agreement" id="agreement" required class="accent-[#c5a059] w-4 h-4 mt-1 flex-shrink-0">
          <span class="text-[0.9rem] text-link">I understand this withdrawal request will be processed in accordance with the Child Care Center's policies and that the required notice period applies. <span class="text-accent">*</span></span>
        </label>
      </div>

      <div id="form-status" class="mb-4 text-[0.9rem]"></div>

      <button type="submit" id="submit-btn" class="px-[24px] py-[10px] border border-accent text-accent uppercase tracking-[2px] text-[0.85rem] hover:bg-accent hover:text-dark-bg transition-colors duration-300 cursor-pointer disabled:opacity-50">
        Submit
      </button>
    </form>
  </div>

</div>

<script>
  document.getElementById('withdrawal-form').addEventListener('submit', async function (e) {
    e.preventDefault();
    const btn = document.getElementById('submit-btn');
    const status = document.getElementById('form-status');
    const wrapper = document.getElementById('form-wrapper');

    if (!this.checkValidity()) {
      this.reportValidity();
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Submitting...';
    status.textContent = '';

    try {
      const res = await fetch('/api/submit-form', { method: 'POST', body: new FormData(this) });
      if (res.ok) {
        wrapper.innerHTML = '<div class="text-center py-[60px]"><p class="text-accent text-[1.5rem] uppercase tracking-[4px] mb-4">Thank You!</p><p class="text-link">Your withdrawal request has been successfully submitted. We will be in touch shortly.</p></div>';
      } else {
        status.textContent = 'There was an error submitting the form. Please try again or contact us directly.';
        status.className = 'mb-4 text-[0.9rem] text-red-400';
        btn.disabled = false;
        btn.textContent = 'Submit';
      }
    } catch {
      status.textContent = 'There was an error submitting the form. Please try again or contact us directly.';
      status.className = 'mb-4 text-[0.9rem] text-red-400';
      btn.disabled = false;
      btn.textContent = 'Submit';
    }
  });
</script>
