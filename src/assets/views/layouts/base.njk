<!DOCTYPE html>
<html lang="{{ lang or 'en' }}" dir="{{ dir or 'ltr' }}">
  <head>
    {#- Stylesheet -#}
    <link rel="stylesheet" href="{{ '/assets/styles/styles.css' | url }}"/>

    {#- Favicon -#}
    <link rel="icon" type="image/svg+xml" href="/assets/images/favicon.svg">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400..700;1,400..700&family=Playfair+Display:ital,wght@0,400..900;1,400..900&display=swap" rel="stylesheet">

    {#- Page title, meta tags, and other head elements -#}
    {%- include "partials/meta.njk" -%}
  </head>
  <body>
    {#- Skip to content link -#}
    <a class="visually-hidden" href="#main">Skip to content</a>

    {#- Site header with navigation -#}
    <header>
      {%- include "partials/navigation.njk" -%}
    </header>

    {#- Main content -#}
    <main id="main" tabindex="-1" data-pagefind-body>
      {#- Content from the page or post -#}
      {{ content | safe }}
    </main>

    {#- Site footer with copyright -#}
    <footer id="footer">
      {#-{%- year -%} &copy; {{ site.name }}-#}
      <div id="footerContainer">
        <div class="footerItem">
          <h3>Church</h3>
          <div>
            <div>9:00am — Bible Study</div>
            <div>10:15am — Divine Service</div>
            <div style="margin-top: 15px;">Wednesdays: <br/> <i>(During Advent & Lent)</i><br/>12:00pm — Matins<br/>7:00pm — Vespers</div>
            <div style="margin-top: 15px;">Private Confession & Absolution is available <br/>with Pastor by appointment.</div>
          </div>
        </div>
        <div class="footerItem">
          <h3>Office & Child Care</h3>
          <div>Child Care Hours: 7am — 6pm, Mon — Fri</div>
          <div>Church Office:</div>
          <div>
            <div>Sunday, 7am — 1pm</div>
            <div>Monday,	7am — 6pm</div>
            <div>Tuesday,	7am — 6pm</div>
            <div>Wednesday,	7am — 6pm</div>
            <div>Thursday,	7am — 6pm</div>
            <div>Friday,	7am — 6pm</div>
            <div>Saturday,	Closed</div>
          </div>
        </div>
        <div class="footerItem">
          <h3>Address</h3>
          <div>
            <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2940.1335593795966!2d-83.21727302349028!3d42.531217524270446!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8824c7b6cc71f3ef%3A0xfd3e4ae3fd68d2fb!2sAscension%20of%20Christ%20Lutheran%20Church%20%26%20Child%20Care!5e0!3m2!1sen!2sus!4v1773624524518!5m2!1sen!2sus" width="250" height="200" style="border:0;" allowfullscreen="" class="map" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
          </div>
          <div>
            <a href="https://maps.app.goo.gl/B4REv35mR9xof49B8" target="_blank">
              16935 W 14 Mile Rd, Beverly Hills, MI 48025
            </a>
          </div>
        </div>
      </div>
    </footer>

    {#- Script bundle -#}
    <script src="{{ '/assets/scripts/main.js' | url }}"></script>
  </body>
</html>
